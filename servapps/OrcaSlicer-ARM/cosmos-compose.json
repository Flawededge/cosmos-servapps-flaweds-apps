{
  "cosmos-installer": {
    "form": [
      {
        "name": "imageTag",
        "label": "Which OrcaSlicer image tag do you want to use? Use latest for nightly builds.",
        "initialValue": "v2.3.0",
        "type": "text"
      },
      {
        "name": "configPath",
        "label": "Where do you want to store OrcaSlicer configuration?",
        "initialValue": "{DefaultDataPath}/orcaslicer-arm/config",
        "type": "text"
      },
      {
        "name": "enableDri",
        "label": "Expose /dev/dri for hardware rendering?",
        "initialValue": true,
        "type": "checkbox"
      },
      {
        "name": "adminOnly",
        "label": "Do you want to make this service admin only?",
        "initialValue": true,
        "type": "checkbox"
      },
      {
        "name": "useSwapfile",
        "label": "Use swapfile mode instead of RAM-only mode? Enable this for devices with less than 4 GB RAM.",
        "initialValue": false,
        "type": "checkbox"
      }
      {if Context.useSwapfile}
      ,
      {
        "type": "warning",
        "label": "Swapfile mode starts a privileged helper container that creates /cosmos-orcaslicer.swap on the host and adds it to /etc/fstab."
      }
      {/if}
    ],
    "post-install": [
      {
        "type": "info",
        "label": "Open OrcaSlicer from the created route. If you selected latest, Docker will track nightly builds."
      }
      {if Context.useSwapfile}
      ,
      {
        "type": "warning",
        "label": "Swapfile helper remains running so it can re-enable /cosmos-orcaslicer.swap after container restarts. Remove that file and its /etc/fstab line manually if you uninstall and no longer want the swapfile."
      }
      {/if}
    ]
  },
  "minVersion": "0.9.0",
  "services": {
    "{ServiceName}": {
      "image": "matszwe02/orcaslicer-arm:{Context.imageTag}",
      "container_name": "{ServiceName}",
      "restart": "unless-stopped",
      {if Context.useSwapfile}
      "depends_on": {
        "{ServiceName}-swapfile": {}
      },
      {/if}
      "cap_add": [
        "SYS_NICE"
      ],
      {if Context.enableDri}
      "devices": [
        "/dev/dri:/dev/dri"
      ],
      {/if}
      "environment": [
        "TZ=auto"
      ],
      "labels": {
        "cosmos-force-network-secured": "true",
        "cosmos-auto-update": "true",
        "cosmos-icon": "https://flawededge.github.io/cosmos-servapps-flaweds-apps/servapps/OrcaSlicer-ARM/icon.png",
        "cosmos-stack": "{ServiceName}",
        "cosmos-stack-main": "{ServiceName}"
      },
      "volumes": [
        {
          "source": "{Context.configPath}",
          "target": "/config/.config/OrcaSlicer",
          "type": "bind"
        }
      ],
      "shm_size": "1gb",
      "routes": [
        {
          "name": "{ServiceName}",
          "description": "Expose {ServiceName} to the web",
          "useHost": true,
          "target": "http://{ServiceName}:3000",
          "mode": "SERVAPP",
          "Timeout": 14400000,
          "ThrottlePerMinute": 12000,
          "BlockCommonBots": true,
          "SmartShield": {
            "Enabled": true
          },
          "AuthEnabled": true
          {if Context.adminOnly}
          , "AuthAdmin": true
          {/if}
        }
      ]
    }
    {if Context.useSwapfile}
    ,
    "{ServiceName}-swapfile": {
      "image": "alpine:3.20",
      "container_name": "{ServiceName}-swapfile",
      "restart": "unless-stopped",
      "network_mode": "none",
      "privileged": true,
      "command": "sh -c 'set -eu; swapfile=/host/cosmos-orcaslicer.swap; if ! grep -q cosmos-orcaslicer.swap /proc/swaps; then rm -f $swapfile; fallocate -l 4G $swapfile || dd if=/dev/zero of=$swapfile bs=1M count=4096; chmod 600 $swapfile; mkswap $swapfile; swapon $swapfile; fi; grep -q cosmos-orcaslicer.swap /host/etc/fstab || echo /cosmos-orcaslicer.swap swap swap defaults 0 0 >> /host/etc/fstab; tail -f /dev/null'",
      "labels": {
        "cosmos-auto-update": "true",
        "cosmos-icon": "https://flawededge.github.io/cosmos-servapps-flaweds-apps/servapps/OrcaSlicer-ARM/icon.png",
        "cosmos-stack": "{ServiceName}",
        "cosmos-stack-main": "{ServiceName}"
      },
      "volumes": [
        {
          "source": "/",
          "target": "/host",
          "type": "bind"
        }
      ]
    }
    {/if}
  }
}
